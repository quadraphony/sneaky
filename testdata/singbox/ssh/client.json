{
  "log": {
    "level": "info"
  },
  "inbounds": [
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "127.0.0.1",
      "listen_port": 2098
    }
  ],
  "outbounds": [
    {
      "type": "ssh",
      "tag": "ssh-out",
